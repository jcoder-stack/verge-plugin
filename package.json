{
  "name": "verge-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Clash Verge 订阅覆写生成器 - 解析代理订阅/YAML，可视化选择中转节点并生成新 YAML",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test test/*.test.js core/test/*.test.js",
    "postinstall": "cd core && npm install"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "js-yaml": "^4.1.0"
  }
}
